# Copia aquest fitxer a .env i posa-hi les dades d'Odoo.
# No comparteixis mai la clau ni la pugis a Git.
ODOO_URL=https://la-teva-empresa.odoo.com
ODOO_DB=nom_base_de_dades
ODOO_USERNAME=usuari@empresa.com
ODOO_API_KEY=posa_la_teva_api_key_aqui

# Opcional: nom de la unitat de mesura de metres quadrats a Odoo.
ODOO_M2_UOM=m2
